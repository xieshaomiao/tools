.hero {
  overflow: hidden;
  padding: 42rpx 36rpx;
  background: linear-gradient(145deg, #0f172a, #1e3a8a 65%, #2563eb);
  color: #ffffff;
}

.hero-topline {
  color: #bfdbfe;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.hero-title {
  margin-top: 24rpx;
  font-size: 48rpx;
  font-weight: 750;
  line-height: 1.25;
}

.hero-copy {
  margin-top: 20rpx;
  color: #dbeafe;
  font-size: 27rpx;
  line-height: 1.75;
}

.hero-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 34rpx;
}

.metric {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  color: #dbeafe;
  font-size: 23rpx;
}

.metric-number {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
}

.about-button {
  margin: 0;
  padding: 0 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
  font-size: 24rpx;
  line-height: 68rpx;
}

.about-button::after {
  border: 0;
}

.search {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 26rpx;
  padding: 22rpx 28rpx;
}

.search-icon {
  color: #64748b;
  font-size: 40rpx;
}

.search input {
  flex: 1;
  font-size: 28rpx;
}

.category-scroll {
  box-sizing: border-box;
  width: 100%;
  margin: 28rpx 0 8rpx;
  white-space: nowrap;
}

.category-row {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 2rpx 8rpx;
}

.category-chip {
  padding: 17rpx 26rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 999rpx;
  background: #ffffff;
  color: #475569;
  font-size: 24rpx;
}

.category-chip-active {
  border-color: #0f172a;
  background: #0f172a;
  color: #ffffff;
}

.section-title {
  margin: 34rpx 4rpx 20rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.tool-card {
  box-sizing: border-box;
  min-height: 300rpx;
  padding: 26rpx;
}

.tool-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 72rpx;
  height: 56rpx;
  padding: 0 14rpx;
  border-radius: 18rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 700;
}

.tool-title {
  margin-top: 22rpx;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.35;
}

.tool-description {
  display: -webkit-box;
  overflow: hidden;
  margin-top: 12rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.6;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.tool-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  color: #94a3b8;
  font-size: 21rpx;
}

.tool-arrow {
  color: #2563eb;
  font-size: 30rpx;
}

.empty {
  padding: 70rpx 30rpx;
  color: #64748b;
  text-align: center;
}
