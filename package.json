{
  "name": "toolly-online-tools",
  "version": "1.0.0",
  "description": "Free online PDF document converter, image tools, Chinese office utilities, and developer toolbox built with Next.js.",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "prebuild": "node ./scripts/preparePdfAssets.mjs",
    "build": "next build",
    "start": "next start",
    "check": "tsc --noEmit",
    "lint": "npm run check",
    "cap:add-android": "npx cap add android",
    "cap:add-ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "deploy:vercel": "vercel --prod",
    "ad:validate": "node ./scripts/validateAdsPlaceholder.js",
    "monetization:audit": "node ./scripts/monetizationAudit.mjs",
    "seo:audit": "node ./scripts/seoAudit.mjs",
    "seo:submit-indexnow": "node ./scripts/submitIndexNow.mjs"
  },
  "keywords": [
    "online-tools",
    "pdf-converter",
    "pdf-to-word",
    "word-to-pdf",
    "document-converter",
    "online-pdf-converter",
    "image-compressor",
    "image-converter",
    "json-formatter",
    "json-csv",
    "image-tools",
    "developer-tools",
    "chinese-office-tools",
    "nextjs",
    "toolly"
  ],
  "author": "xieshaomiao",
  "license": "ISC",
  "type": "module",
  "homepage": "https://toolly-ruddy.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/xieshaomiao/tools.git"
  },
  "bugs": {
    "url": "https://github.com/xieshaomiao/tools/issues"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@neondatabase/serverless": "^1.1.0",
    "docx": "^9.7.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "next": "^16.2.10",
    "pdfjs-dist": "^5.7.284",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/node": "^26.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "playwright-core": "^1.61.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.13",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
